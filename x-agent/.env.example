# =============================================================================
# X-Agent v3.0 环境变量配置
# =============================================================================
# 说明：
# 1. 复制此文件为 .env
# 2. 根据下方说明填写必填项（✅）
# 3. 选填项可根据需要配置（❌）
# 4. 不要修改此文件，只修改 .env
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram 配置 (✅ 必填)
# -----------------------------------------------------------------------------
# 获取方式：在 Telegram 中搜索 @BotFather，发送 /newbot 创建 Bot
# 详细教程：https://core.telegram.org/bots#how-do-i-create-a-bot
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-6789jklmnopqrst

# 获取方式：向 @userinfobot 发送任意消息获取你的 Chat ID
# 群组 Chat ID 通常为负数，如 -1001234567890
TELEGRAM_CHAT_ID=-1001234567890

# -----------------------------------------------------------------------------
# Supabase 数据库配置 (✅ 必填)
# -----------------------------------------------------------------------------
# 获取方式：
# 1. 访问 https://supabase.com 注册账号
# 2. 创建新项目，记录项目 URL
# 3. Settings -> API -> 复制 project api keys 中的 anon 或 service_role key
# 4. 在 SQL Editor 中运行 migrations/001_initial_schema.sql 初始化数据库
SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ...

# -----------------------------------------------------------------------------
# LLM 供应商配置 (✅ 至少填写一个)
# -----------------------------------------------------------------------------
# 推荐使用 Anthropic（质量高）或 Groq（免费额度高）
# 获取方式见 CONFIG.md 或各平台官网

# Anthropic (推荐) - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# Groq (免费额度高) - https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# Gemini - https://makersuite.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# OpenRouter (聚合多个模型) - https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxx

# NVIDIA NIM - https://build.nvidia.com/explore/discover
NVIDIA_NIM_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# Ollama (本地部署，无需 API Key) - https://ollama.com
# 安装后运行：ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# 默认 LLM 配置 (❌ 选填，默认值已设置)
# -----------------------------------------------------------------------------
# 默认使用的 LLM 供应商：anthropic, openai, groq, gemini, openrouter, nvidia, ollama
LLM_PROVIDER=anthropic

# 默认使用的模型
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Groq: llama-3.3-70b-versatile, mixtral-8x7b-32768
# Gemini: gemini-2.0-flash-exp, gemini-pro
# 等等...
LLM_MODEL=claude-3-5-sonnet-20241022

# -----------------------------------------------------------------------------
# Base URL 配置 (❌ 选填，默认值已设置)
# -----------------------------------------------------------------------------
# OpenRouter 基础 URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# NVIDIA NIM 基础 URL
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# -----------------------------------------------------------------------------
# Reddit API 配置 (❌ 选填，用于 PRAW 数据源)
# -----------------------------------------------------------------------------
# 获取方式：https://www.reddit.com/settings/apps
REDDIT_CLIENT_ID=xxxxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxxxx
REDDIT_USER_AGENT=x-agent/3.0

# -----------------------------------------------------------------------------
# X (Twitter) Playwright 真实爬虫配置 (❌ 选填，用于真实搜索推文内容)
# -----------------------------------------------------------------------------
# 填写后，/search 命令将使用 Playwright 登录 X 账号，搜索真实推文
# 若不填写则使用 trending 标签页（不需要登录）
X_USERNAME=your_email@example.com
X_PASSWORD=your_password

# -----------------------------------------------------------------------------
# OpenClaw 配置 (❌ 选填，用于自动发布到 X)
# -----------------------------------------------------------------------------
# OpenClaw 是一个 X (Twitter) 自动化工具
# 安装：npm install -g openclaw
# 配置：openclaw init && openclaw login
# 启动：openclaw gateway start
OPENCLAW_API_ENDPOINT=http://localhost:8080

# -----------------------------------------------------------------------------
# 防封配置 (❌ 选填，默认值已设置)
# -----------------------------------------------------------------------------
# 每日评论上限，超过后自动停止
MAX_COMMENTS_PER_DAY=15
# 随机延迟范围（秒）
MIN_DELAY_SECONDS=10
MAX_DELAY_SECONDS=40

# -----------------------------------------------------------------------------
# 加密密钥 (❌ 选填，首次启动自动生成)
# -----------------------------------------------------------------------------
# 用于加密存储敏感的 API Key
# 首次启动时会自动生成，无需手动填写
# 如需重置，删除此 key 后重启应用即可
ENCRYPTION_KEY=

# =============================================================================
# 配置完成！
# =============================================================================
# 下一步：
# 1. 将此文件复制为 .env
# 2. 填写必填项（✅ 标记）
# 3. 运行配置验证：python3 modules/config_validator.py
# 4. 启动应用：python3 main.py
#
# 详细配置说明见 CONFIG.md
# =============================================================================
