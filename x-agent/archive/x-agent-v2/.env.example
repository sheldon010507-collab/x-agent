# X 智能运营 Agent v2.0
# 多 Niche 内容自动化系统

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# LLM 供应商（按需填写，支持多供应商）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_NIM_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# 默认 LLM 配置
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# OpenRouter / NVIDIA NIM 配置
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Reddit (用于 PRAW)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=x-agent/2.0

# OpenClaw
OPENCLAW_API_ENDPOINT=http://localhost:8080

# 加密密钥（首次启动自动生成，勿手动修改）
ENCRYPTION_KEY=
